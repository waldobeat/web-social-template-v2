# Firebase Configuration
# Copia este archivo a .env y llena los valores con tu configuración de Firebase

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Security - App Check (reCAPTCHA Enterprise)
# Obtén tu Site Key desde: https://console.cloud.google.com/security/recaptcha
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# Development Mode (set to 'true' only for local testing)
VITE_USE_DEBUG_APP_CHECK=false
