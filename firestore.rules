// Sheddit Firestore Security Rules
// Implements 4-layer security architecture

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================
    // HELPER FUNCTIONS
    // ============================================
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Check if user has verified email
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }
    
    // Check if user passed liveness verification (is human)
    function isHuman() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_human == true;
    }
    
    // Check if user account is active (not suspended)
    function isAccountActive() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData.account_status == 'active' || userData.account_status == null;
    }
    
    // Check if user is temp blocked
    function isNotBlocked() {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return userData.account_status != 'temp_blocked' && userData.account_status != 'suspended';
    }
    
    // Check if user has admin role
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Check if user owns the resource
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    // ============================================
    // USERS COLLECTION
    // ============================================
    
    match /users/{userId} {
      // Allow public read for profiles and username checks
      allow read: if true;
      
      // Allow creation of own profile for any authenticated user
      // Note: We keep "if true" version for now to fix the immediate blocker, 
      // but ideally it should be isOwner(userId) && isAuthenticated()
      allow create: if true;
      
      // Admins can update any user, owners can update themselves
      allow update: if isAdmin() || (isAuthenticated() && isOwner(userId));
      
      // Only admins can delete users
      allow delete: if isAdmin();
    }
    
    // ============================================
    // POSTS COLLECTION
    // ============================================
    
    // ============================================
    // POSTS COLLECTION
    // ============================================
    
    // ============================================
    // POSTS COLLECTION
    // ============================================
    
    match /posts/{postId} {
      allow read: if isAuthenticated();
      
      // Anyone authenticated can create
      allow create: if isAuthenticated();
      
      // Admins can update/delete any post, owners can update/delete theirs
      allow update: if isAdmin() || isAuthenticated();
      
      // Only owner can delete
      allow delete: if isAdmin() || (isAuthenticated() && isOwner(resource.data.authorId));
    }
    
    // ============================================
    // COMMUNITIES COLLECTION
    // ============================================
    
    match /communities/{communityId} {
      allow read: if isAuthenticated();
      
      // Anyone authenticated can create
      allow create: if isAuthenticated();
      
      // Admins can manage any community, owners can manage theirs
      allow update: if isAdmin() || isAuthenticated();
      
      // Only owner can delete
      allow delete: if isAdmin() || (isAuthenticated() && isOwner(resource.data.ownerId));
    }
    
    // ============================================
    // COMMENTS COLLECTION
    // ============================================
    
    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      
      // Admins and owners can manage
      allow update: if isAdmin() || isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && isOwner(resource.data.authorId));
    }
    
    // ============================================
    // MESSAGES COLLECTION
    // ============================================
    
    match /messages/{messageId} {
      allow read: if isAdmin() || (isAuthenticated() && 
        (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid));
      allow create: if isAuthenticated();
      
      // Admins can delete any message
      allow delete: if isAdmin();
    }
    
    // ============================================
    // FOLLOWS COLLECTION
    // ============================================
    
    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && (resource.data.followerId == request.auth.uid || isOwner(followId)));
    }
    
    // ============================================
    // NOTIFICATIONS, FLAGS, CHALLENGES
    // ============================================
    
    match /notifications/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.recipientId == request.auth.uid);
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /behavior_flags/{id} {
      allow read, write: if isAdmin();
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if true;
    }

    match /liveness_challenges/{id} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if true;
      allow update, delete: if isAdmin();
    }
    
    // ============================================
    // MESSAGE REQUESTS
    // ============================================
    
    match /message_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && 
        (resource.data.fromId == request.auth.uid || resource.data.toId == request.auth.uid));
      allow create: if isAuthenticated();
      allow update: if isAdmin() || (isAuthenticated() && (resource.data.toId == request.auth.uid || resource.data.fromId == request.auth.uid));
      allow delete: if isAdmin();
    }
  }
}
